import hashlib
import os
import json
import subprocess
import magic
from pathlib import Path
import concurrent.futures
from datetime import datetime


class ForensicsScraper:
    def __init__(self, exiftool_path="exiftool"):
        self.exiftool_path = exiftool_path

    def get_sha256(self, file_path):
        """Calculates SHA256 hash for cryptographic integrity."""
        sha256_hash = hashlib.sha256()
        try:
            with open(file_path, "rb") as f:
                for byte_block in iter(lambda: f.read(4096), b""):
                    sha256_hash.update(byte_block)
            return sha256_hash.hexdigest()
        except Exception as e:
            return f"ERROR: {str(e)}"

    def get_true_file_type(self, file_path):
        """Uses libmagic to determine the real file type, ignoring extensions."""
        try:
            return magic.from_file(str(file_path), mime=True)
        except Exception as e:
            return f"ERROR: {str(e)}"

    def get_mac_times(self, file_path):
        """Extracts OS-level Modified, Accessed, and Created timestamps."""
        try:
            stat = os.stat(file_path)
            return {
                "created": datetime.fromtimestamp(stat.st_ctime).isoformat(),
                "modified": datetime.fromtimestamp(stat.st_mtime).isoformat(),
                "accessed": datetime.fromtimestamp(stat.st_atime).isoformat()
            }
        except Exception as e:
            return {"error": str(e)}

    def get_exiftool_metadata(self, file_path):
        """Calls ExifTool to extract ALL internal metadata, including GPS."""
        try:
            cmd = [self.exiftool_path, "-j", "-n", str(file_path)]
            result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)

            if result.returncode == 0:
                metadata = json.loads(result.stdout)[0]

                filtered_data = {k: v for k, v in metadata.items() if not k.startswith("ExifTool")}
                return filtered_data
            else:
                return {"error": result.stderr.strip()}
        except FileNotFoundError:
            return {"error": "ExifTool not found. Ensure it is installed and in your system PATH."}
        except Exception as e:
            return {"error": str(e)}

    def process_file(self, file_path):
        """The main processing pipeline for a single file."""
        file_path = Path(file_path)
        report = {
            "file_name": file_path.name,
            "absolute_path": str(file_path.absolute()),
            "sha256": self.get_sha256(file_path),
            "mime_type": self.get_true_file_type(file_path),
            "os_timestamps": self.get_mac_times(file_path),
            "internal_metadata": self.get_exiftool_metadata(file_path)
        }
        return report


def scan_directory(directory_path, workers=4):
    """Scans a directory concurrently and outputs a master JSON report."""
    scraper = ForensicsScraper()
    target_dir = Path(directory_path)
    all_reports = []

    files_to_process = [f for f in target_dir.rglob("*") if f.is_file()]
    print(f" Found {len(files_to_process)} files. Starting concurrent processing...")

    with concurrent.futures.ThreadPoolExecutor(max_workers=workers) as executor:
        future_to_file = {executor.submit(scraper.process_file, f): f for f in files_to_process}

        for future in concurrent.futures.as_completed(future_to_file):
            try:
                data = future.result()
                all_reports.append(data)
                print(f"Processed: {data['file_name']}")
            except Exception as e:
                print(f"Error processing file: {e}")

    output_file = "forensics_report.json"
    with open(output_file, "w") as f:
        json.dump(all_reports, f, indent=4)

    print(f"Scan complete. Report saved to {output_file}")


